# Interpolation config for docker-compose.theworks.yml (the Voltini support-case
# cutover stack — issue #45). Copy to .env.theworks and fill in.
#
#   docker compose -f docker-compose.theworks.yml --env-file .env.theworks up -d
#
# LEAST PRIVILEGE — three env files, each seen by the fewest processes possible:
#   • .env.theworks         (THIS FILE) — passed to the compose CLI via
#                             `--env-file`. Used ONLY for `${...}` interpolation
#                             in the compose file; it is NOT injected wholesale
#                             into any container. Holds shared infra + the DB
#                             credential (postgres + theworks-cases-be reference
#                             it via their `environment:` blocks; the worker never
#                             does, so the worker never receives DB_PASSWORD).
#   • .env.theworks.be      — injected ONLY into the theworks-cases-be container.
#   • .env.theworks.worker  — injected ONLY into the theworks-cases-worker container.
# So a compromised worker image never holds the GitHub mirror token / AWS keys /
# webhook secret, and a compromised backend image never holds the Claude OAuth
# token / worker GitHub PAT / agent-worker token. Secrets live ONLY in these
# files — never in committed config or JSON.

# --- Images -------------------------------------------------------------------
# Registry the theworks-cases-be / theworks-cases-worker images are published to
# from their own repos (e.g. a GHCR path or an ECR registry host). This bundle
# only orchestrates the images; it holds no application source.
THEWORKS_REGISTRY=ghcr.io/digistrada
THEWORKS_CASES_BE_TAG=latest
THEWORKS_CASES_WORKER_TAG=latest
# Port theworks-cases-be listens on inside its container (internal network only).
# Drives BOTH sides: it is injected as PORT into the theworks-cases-be service
# (its listen port) and into the worker's CENTRAL_API_BASE_URL (its client URL),
# so moving the port here keeps the two in lockstep. Must be a port the image's
# server actually binds via the PORT env override.
THEWORKS_CASES_BE_PORT=3000

# --- Shared Postgres ----------------------------------------------------------
# One Postgres instance, two databases. DB_NAME is the PRIMARY (Voltini)
# database; THEWORKS_DB_NAME is the SEPARATE database that scripts/theworks-initdb.sh
# provisions on first cluster init and that theworks-cases-be connects to.
# The two share one credential (only the database name differs). Interpolated
# into the postgres + theworks-cases-be `environment:` blocks — the worker,
# which keeps no local DB, never references these.
DB_NAME=voltini
DB_USER=voltini
DB_PASSWORD=
THEWORKS_DB_NAME=theworks_cases

# --- Worker → central live-data endpoint --------------------------------------
# Interpolated into the theworks-cases-worker service. Live installation data for
# the voltini hook comes from Voltini central (voltini.energy-backend), the
# live-energy authority — never from the cases backend. Not a secret.
LIVE_DATA_API_URL=https://api.voltini.energy
