# Configuration for docker-compose.theworks.yml (the Voltini support-case
# cutover stack — issue #45). Copy to .env.theworks and fill in.
# Secrets live ONLY here — never in committed config or JSON.
#
#   docker compose -f docker-compose.theworks.yml --env-file .env.theworks up -d

# --- Images -------------------------------------------------------------------
# Registry the theworks-cases-be / theworks-cases-worker images are published to
# from their own repos (e.g. a GHCR path or an ECR registry host). This bundle
# only orchestrates the images; it holds no application source.
THEWORKS_REGISTRY=ghcr.io/digistrada
THEWORKS_CASES_BE_TAG=latest
THEWORKS_CASES_WORKER_TAG=latest
# Port theworks-cases-be listens on inside its container (internal network only).
THEWORKS_CASES_BE_PORT=3000

# --- Shared Postgres ----------------------------------------------------------
# One Postgres instance, two databases. DB_NAME is the PRIMARY (Voltini)
# database; THEWORKS_DB_NAME is the SEPARATE database that scripts/theworks-initdb.sh
# provisions on first cluster init and that theworks-cases-be connects to.
# The two share one credential (only the database name differs).
DB_NAME=voltini
DB_USER=voltini
DB_PASSWORD=
THEWORKS_DB_NAME=theworks_cases

# --- theworks-cases-be (support-case system of record) ------------------------
# casesConfig/GitHub-mirror/webhook/SES/S3/Bedrock values are read from the
# image's config/config.Production.json; supply only the secrets + endpoints here.
# GitHub mirror → borzoihub/voltini-support (enabled).
GITHUB_TOKEN=
# HMAC secret shared with central's inbound status-webhook receiver.
NOTIFICATIONS_WEBHOOK_SECRET=
# Central's inbound status-webhook receiver (theworks-cases-be POSTs status
# changes here; central verifies the HMAC and fans out the app push).
NOTIFICATIONS_WEBHOOK_URL=https://api.voltini.energy/api/support/webhooks/status
# AWS (SES sender + S3 bucket + Bedrock model) used by theworks-cases-be.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- theworks-cases-worker (autonomous resolver) ------------------------------
# The worker authenticates to theworks-cases-be's /api/agent/* with an
# agentWorker service token minted in theworks-cases-be.
AGENT_WORKER_TOKEN=
# Live installation data for the voltini hook comes from Voltini central
# (voltini.energy-backend), the live-energy authority — never from the cases backend.
LIVE_DATA_API_URL=https://api.voltini.energy

# Claude backend (subscription OAuth) — mint once with `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=
# First-party model id (NOT the Bedrock-prefixed one).
MODEL=claude-opus-4-8

# GitHub PAT the worker uses to push branches + open PRs against the Voltini code
# repos (classic PAT: `repo` + `read:packages`, authorized for every target org).
GH_TOKEN=
BOT_GH_LOGIN=voltini-autobot

# Behaviour knobs (see theworks-cases-worker docs for the full list).
POLL_INTERVAL_SEC=120
MAX_BUDGET_PER_CASE_USD=50
