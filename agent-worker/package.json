{
  "name": "voltini-bugfixer",
  "version": "0.1.0",
  "description": "Autonomous support-case resolver for the Voltini ecosystem. Polls borzoihub/voltini-support, triages, fixes across code repos via the Claude Agent SDK, self-reviews, and opens PRs.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/main.ts",
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "backfill": "tsx --env-file-if-exists=.env src/backfill.ts",
    "test": "mocha",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@digistrada/theworks-common": "^1.0.127",
    "dayjs": "^1.11.21",
    "tsx": "^4.19.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "chai": "^5.1.2",
    "mocha": "^11.0.1",
    "typescript": "^5.7.2"
  }
}
