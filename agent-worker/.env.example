# voltini-bugfixer configuration. Copy to .env and fill in.
# Secrets live ONLY here — never in committed config or JSON.

# --- Claude backend (subscription OAuth) --------------------------------------
# The Agent SDK authenticates against a Claude subscription (Pro/Max) — no
# per-token API/Bedrock billing. Mint a long-lived (~1 year) token once on any
# machine with a browser, logged into your subscription:
#   claude setup-token
# then paste it here. Regenerate before it expires.
CLAUDE_CODE_OAUTH_TOKEN=

# First-party model id (NOT the Bedrock-prefixed one).
MODEL=claude-opus-4-8

# --- GitHub -------------------------------------------------------------------
# Fine-grained PAT: Issues:RW on the support repo + Contents:RW & Pull-requests:RW
# on every code repo the bot may push to.
GH_TOKEN=
# The GitHub login of the bot account, used to tell bot comments from human replies.
BOT_GH_LOGIN=voltini-autobot
SUPPORT_REPO=borzoihub/voltini-support

# --- Repos --------------------------------------------------------------------
# Folder of pre-cloned repos the bot may work on. A human clones repos here;
# any git repo found is workable. (Mounted from ./agent-data/repos by compose.)
REPOS_DIR=/data/repos

# --- Behaviour ----------------------------------------------------------------
POLL_INTERVAL_SEC=120
MAX_REVIEW_ITERS=5
MAX_TEST_ATTEMPTS=4
MAX_IMPLEMENT_TURNS=120
# Hard ceiling on the notional API cost (USD) of resolving ONE support case,
# summed across all its Agent SDK sessions. Primary runaway guard; the turn caps
# are only a secondary backstop. Notional because billing is via a Claude
# subscription, but it's a faithful proxy for tokens spent. Sessions hard-fail to
# needs-human when it's exhausted; only the advisory review read-pass soft-fails
# (ships the tested work, flags review incomplete on close).
MAX_BUDGET_PER_CASE_USD=50
STATE_DB=/data/state.sqlite
