# voltini-bugfixer configuration. Copy to .env and fill in.
# Secrets live ONLY here — never in committed config or JSON.

# --- Claude backend (AWS Bedrock) ---------------------------------------------
# Same var names as borzoi-backend. When the BEDROCK_ creds are present the
# worker uses Bedrock and maps these onto the AWS vars the Agent SDK expects.
BEDROCK_REGION=eu-west-1
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=

# Model id (borzoi keeps this in JSON config; here it's an env for the worker).
BEDROCK_MODEL=eu.anthropic.claude-opus-4-8
# Optional fallback if Bedrock ever lags the latest Opus: leave the BEDROCK_
# creds blank and provide a first-party key instead.
# ANTHROPIC_API_KEY=

# --- GitHub -------------------------------------------------------------------
# Fine-grained PAT: Issues:RW on the support repo + Contents:RW & Pull-requests:RW
# on every code repo the bot may push to.
GH_TOKEN=
# The GitHub login of the bot account, used to tell bot comments from human replies.
BOT_GH_LOGIN=voltini-autobot
SUPPORT_REPO=borzoihub/voltini-support

# --- Repos --------------------------------------------------------------------
# Folder of pre-cloned repos the bot may work on. A human clones repos here;
# any git repo found is workable. (Mounted from ./agent-data/repos by compose.)
REPOS_DIR=/data/repos

# --- Behaviour ----------------------------------------------------------------
POLL_INTERVAL_SEC=120
MAX_REVIEW_ITERS=5
MAX_TEST_ATTEMPTS=4
MAX_IMPLEMENT_TURNS=120
STATE_DB=/data/state.sqlite

# Set to 1 to skip every customer-facing GitHub mutation (label/close/comment/PR)
# and log what would happen instead. Use for the first end-to-end exercise.
DRY_RUN=1
