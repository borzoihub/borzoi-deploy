# voltini-bugfixer configuration. Copy to .env and fill in.
# Secrets live ONLY here — never in committed config or JSON.

# --- Claude backend (subscription OAuth) --------------------------------------
# The Agent SDK authenticates against a Claude subscription (Pro/Max) — no
# per-token API/Bedrock billing. Mint a long-lived (~1 year) token once on any
# machine with a browser, logged into your subscription:
#   claude setup-token
# then paste it here. Regenerate before it expires.
CLAUDE_CODE_OAUTH_TOKEN=

# First-party model id (NOT the Bedrock-prefixed one).
MODEL=claude-opus-4-8

# --- GitHub -------------------------------------------------------------------
# Fine-grained PAT: Issues:RW on the support repo + Contents:RW & Pull-requests:RW
# on every code repo the bot may push to.
GH_TOKEN=
# The GitHub login of the bot account, used to tell bot comments from human replies.
BOT_GH_LOGIN=voltini-autobot
SUPPORT_REPO=borzoihub/voltini-support

# --- Repos --------------------------------------------------------------------
# Folder of pre-cloned repos the bot may work on. A human clones repos here;
# any git repo found is workable. (Mounted from ./agent-data/repos by compose.)
REPOS_DIR=/data/repos

# --- Behaviour ----------------------------------------------------------------
POLL_INTERVAL_SEC=120
MAX_REVIEW_ITERS=5
MAX_TEST_ATTEMPTS=4
# Hard ceiling on the notional API cost (USD) of resolving ONE support case,
# summed across all its Agent SDK sessions. This is the SOLE session guard — we
# set no turn cap, so a complex (= expensive) task runs until it finishes or
# spends this budget. Notional because billing is via a Claude subscription, but
# it's a faithful proxy for tokens spent. Sessions hard-fail to needs-human when
# it's exhausted; only the advisory review read-pass soft-fails (ships the tested
# work, flags review incomplete on close). Advanced portal cases may raise their
# own ceiling above this via a per-case budget override.
MAX_BUDGET_PER_CASE_USD=50

# --- Central backend (voltini.energy-backend) ---------------------------------
# The worker keeps NO local DB — central is the single source of truth for all
# case state (phase, cost, PR links, per-repo sub-tasks) and the dashboard feed.
# CENTRAL_API_BASE_URL is the backend origin (no trailing path); AGENT_WORKER_TOKEN
# is the long-lived service token minted there with:
#   npm run mint:agent-worker-token   (in voltini.energy-backend)
# Treat the token as a secret; regenerate before its ~1y expiry.
CENTRAL_API_BASE_URL=https://api.voltini.energy
AGENT_WORKER_TOKEN=

# ── Per-case leasing (multi-worker mutual exclusion) ─────────────────────────
# The worker atomically claims each case in central before working it, so two
# runs (an overlapping restart, or a second worker) can't drive the same case.
# Safe with a single worker: the claim always succeeds on an idle case.
#
# WORKER_ID: this instance's lease-owner id. Defaults to <hostname>-<pid> if
# unset. Set a STABLE value per box so a restart reclaims its own in-flight case
# immediately; when running SEVERAL workers, each MUST have a distinct value
# (and its own REPOS_DIR clone set — see docker-compose.agent.yml).
# WORKER_ID=bugfixer-1
#
# AGENT_LEASING_ENABLED: kill-switch (default true). Set false to disable
# claim/heartbeat/release and revert to exactly the pre-leasing behaviour.
# AGENT_LEASING_ENABLED=true
#
# NOTE: the lease TTL is owned by CENTRAL (voltini.energy-backend), not the
# worker — set AGENT_LEASE_SECONDS (default 600) in the backend's environment.
# The worker heartbeats every ~15s, well inside it.
