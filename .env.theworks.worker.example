# Secrets injected ONLY into the theworks-cases-worker container (issue #45).
# Copy to .env.theworks.worker and fill in. Referenced by `env_file:` on the
# theworks-cases-worker service — NEVER handed to the backend.
#
# The worker keeps no local DB and never receives the Postgres credential, the
# GitHub-mirror token, the webhook secret, or the AWS keys — those live in
# .env.theworks / .env.theworks.be and stay with the backend.

# The worker authenticates to theworks-cases-be's /api/agent/* with an
# agentWorker service token minted in theworks-cases-be.
AGENT_WORKER_TOKEN=

# Claude backend (subscription OAuth) — mint once with `claude setup-token`.
CLAUDE_CODE_OAUTH_TOKEN=
# First-party model id (NOT the Bedrock-prefixed one).
MODEL=claude-opus-4-8

# GitHub PAT the worker uses to push branches + open PRs against the Voltini code
# repos (classic PAT: `repo` + `read:packages`, authorized for every target org).
GH_TOKEN=
BOT_GH_LOGIN=voltini-autobot

# Behaviour knobs (see theworks-cases-worker docs for the full list).
POLL_INTERVAL_SEC=120
MAX_BUDGET_PER_CASE_USD=50
