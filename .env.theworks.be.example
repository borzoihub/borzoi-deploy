# Secrets injected ONLY into the theworks-cases-be container (issue #45).
# Copy to .env.theworks.be and fill in. Referenced by `env_file:` on the
# theworks-cases-be service — NEVER handed to the worker.
#
# The DB credential is NOT here: it is supplied through the compose CLI
# `--env-file .env.theworks` and interpolated into this service's `environment:`
# block, so it is shared with postgres without also being handed to the worker.
#
# casesConfig / GitHub-mirror / webhook / SES / S3 / Bedrock behaviour is read
# from the image's config/config.Production.json; supply only the secrets +
# endpoints here.

# GitHub mirror → borzoihub/voltini-support (enabled).
GITHUB_TOKEN=
# HMAC secret shared with central's inbound status-webhook receiver.
NOTIFICATIONS_WEBHOOK_SECRET=
# Central's inbound status-webhook receiver (theworks-cases-be POSTs status
# changes here; central verifies the HMAC and fans out the app push).
NOTIFICATIONS_WEBHOOK_URL=https://api.voltini.energy/api/support/webhooks/status
# AWS (SES sender + S3 bucket + Bedrock model) used by theworks-cases-be.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
