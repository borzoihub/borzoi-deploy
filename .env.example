# Image source — ECR registry (e.g. 123456789012.dkr.ecr.eu-north-1.amazonaws.com)
ECR_REGISTRY=
BACKEND_TAG=latest
FRONTEND_TAG=latest

# Public URL / domain
# The stack binds to http://localhost:8080 on the host. Public access is
# expected via Cloudflare Tunnel (or another reverse proxy). Change these
# two to the real public URL only when email features are active — the
# values end up as links inside outbound mail (password reset, etc.).
BORZOI_DOMAIN=localhost
BORZOI_BASE_URL=http://localhost:8080

# Database (auto-generated by setup.sh — do not edit after first boot;
# postgres only reads POSTGRES_PASSWORD on initial cluster init)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=borzoi
DB_USER=borzoi
DB_PASSWORD=

# Auth (auto-generated)
JWT_SECRET=

# Bootstrap admin (auto-generated; created on first boot only)
BORZOI_ADMIN_EMAIL=
BORZOI_ADMIN_PASSWORD=

# AWS credentials (S3 + SES)
# NOTE: not used by the product today. setup.sh writes placeholder
# values to satisfy the entrypoint's env-var check. Replace with real
# credentials only if/when S3 or SES features become active.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=AKIA-unused-placeholder
AWS_SECRET_ACCESS_KEY=unused-placeholder-secret
S3_BUCKET=borzoi-unused
SES_SENDER=no-reply@borzoi.example

# Self-hosted / embedded mode: allow typeorm synchronize in Production.
# Required for fresh installs without an initial-schema migration.
# Regular SaaS deployments DO NOT set this.
BORZOI_ALLOW_SYNC_IN_PROD=true
